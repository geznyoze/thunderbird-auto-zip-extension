{
  "manifest_version": 2,
  "name": "Auto ZIP Large Attachments",
  "version": "1.1",
  "description": "Prompts to zip attachments greater than 3MB on send.",
  "permissions": [
    "compose",
    "messagesRead"
  ],
  "background": {
    "scripts": [
      "jszip.min.js",
      "background.js"
    ]
  },
  "applications": {
    "gecko": {
      "id": "zip-large-attachments@yourdomain.com",
      "strict_min_version": "115.0"
    }
  }
}